# SoDEX — Sosovalue DEX
# Network: "mainnet" or "testnet"
SODEX_NETWORK=mainnet
# API key name (set via SoDEX account). Required for trading writes and balance queries.
SODEX_API_KEY_NAME=SignalFlowAgent
# API key private key (0x-prefixed hex). Required for signing perps orders (EIP-712).
# Keep secret — never commit this value.
SODEX_API_KEY_PRIVATE=0x-your-api-key-private-key

# WalletConnect v2 (required for mobile wallet connection via QR/deep link)
# Get your project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Database — Supabase Postgres
# DATABASE_URL = Supabase Transaction Pooler (runtime/Vercel/serverless).
# Use the pooler string from Supabase and append:
# ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.njtrqmcatwqbzmtmigjd:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL = Supabase Session Pooler (Prisma migrations only).
# This uses the same pooler host as DATABASE_URL, but port 5432 and no pgbouncer params.
# Supabase Direct Connection also works if your network can reach db.<project-ref>.supabase.co.
DIRECT_URL="postgresql://postgres.njtrqmcatwqbzmtmigjd:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Deepseek (fallback AI agent)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# SoSoValue API — fundamental data (ETF flow, sentiment, macro, treasuries)
SOSOVALUE_API_KEY=SOSO-your-sosovalue-key
